# ApplyIQ — Environment Variables
# Copy this to .env and fill in your values

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://applyiq:applyiq_pass@localhost:5432/applyiq?schema=public"
DIRECT_URL="postgresql://applyiq:applyiq_pass@localhost:5432/applyiq?schema=public"

# ─────────────────────────────────────────────
# REDIS (BullMQ)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# AUTH (NextAuth.js)
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────
# AI — OpenAI / Gemini / Ollama
# ─────────────────────────────────────────────
# Set to your OpenAI API key or Gemini API key (from Google AI Studio) or "ollama" for local LLM
OPENAI_API_KEY="your-api-key"

# Optional: Set to use a free alternative like Gemini or local Ollama
# For Gemini (Free tier): "https://generativelanguage.googleapis.com/v1beta/openai/"
# For Ollama (Local free): "http://localhost:11434/v1"
# OPENAI_API_BASE_URL=""

# Optional: Set model names (Defaults to gpt-4o and text-embedding-3-small)
# For Gemini (Free): "gemini-1.5-flash" (or "gemini-1.5-pro")
# For Ollama (Local): "llama3" (or your local model)
# OPENAI_MODEL_NAME="gpt-4o"

# Optional: Embedding model name and vector dimension
# For Gemini (Free): OPENAI_EMBEDDING_MODEL_NAME="text-embedding-004" and EMBEDDING_DIMENSION="768"
# For Ollama (Local): OPENAI_EMBEDDING_MODEL_NAME="nomic-embed-text" and EMBEDDING_DIMENSION="768"
# OPENAI_EMBEDDING_MODEL_NAME="text-embedding-3-small"
# EMBEDDING_DIMENSION="1536"


# ─────────────────────────────────────────────
# VECTOR DB — Pinecone
# ─────────────────────────────────────────────
# https://app.pinecone.io/
PINECONE_API_KEY="pcsk_6pEaMu_Sy8xNaoL5xtDLhncFXKPE8A64uMpexEHV1huwuPD5bMcMHUymyxgLaNy1Z9DQje"
PINECONE_ENVIRONMENT="us-east-1-aws"
PINECONE_INDEX_NAME="applyiq-jobs"

# ─────────────────────────────────────────────
# JOB APIS
# ─────────────────────────────────────────────
# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_API_KEY="your-adzuna-api-key"

# The Muse — https://www.themuse.com/developers/api/v2
THE_MUSE_API_KEY="your-muse-api-key"

# JSearch via RapidAPI — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_RAPIDAPI_KEY="your-rapidapi-key"
JSEARCH_RAPIDAPI_HOST="jsearch.p.rapidapi.com"

# ─────────────────────────────────────────────
# GMAIL API
# ─────────────────────────────────────────────
GMAIL_CLIENT_ID="${GOOGLE_CLIENT_ID}"
GMAIL_CLIENT_SECRET="${GOOGLE_CLIENT_SECRET}"
GMAIL_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# ─────────────────────────────────────────────
# CLOUDFLARE R2 (Screenshots / File Storage)
# ─────────────────────────────────────────────
# https://dash.cloudflare.com/ → R2 → Manage API tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="applyiq-screenshots"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─────────────────────────────────────────────
# EMAIL (Nodemailer / Gmail SMTP)
# ─────────────────────────────────────────────
SMTP_FROM="noreply@yourdomain.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ─────────────────────────────────────────────
# FASTAPI MICROSERVICE
# ─────────────────────────────────────────────
FASTAPI_URL="http://localhost:8000"
FASTAPI_SECRET_KEY="your-fastapi-internal-secret"

# ─────────────────────────────────────────────
# FIREBASE (Expo Push Notifications)
# ─────────────────────────────────────────────
# https://console.firebase.google.com/
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"

# ─────────────────────────────────────────────
# APP SETTINGS
# ─────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8000"
DRY_RUN_MODE="true"   # Set false to enable real form submissions

# ─────────────────────────────────────────────
# CLEARBIT (Company Logos)
# ─────────────────────────────────────────────
# Free tier available — https://clearbit.com/
CLEARBIT_API_KEY="sk_your_clearbit_key"
