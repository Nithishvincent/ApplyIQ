{
  "name": "applyiq",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered Job Recommendation & Auto-Apply System",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.6.0",
  "scripts": {
    "dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=packages/db/prisma/schema.prisma --force",
    "docker:up": "docker compose up postgres redis -d",
    "docker:down": "docker compose down",
    "docker:up:all": "docker compose up -d",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
